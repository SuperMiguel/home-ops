{
  // ---------------------------------------------------------------------------
  // Automerge alignment with Renovate docs:
  // https://docs.renovatebot.com/key-concepts/automerge/
  //
  // - `:automergeBranch` → prefer merging branches straight to the base when
  //   policy allows; otherwise Renovate falls back to PR automerge.
  // - `platformAutomerge` → use GitHub’s native auto-merge / merge-queue hooks
  //   when a PR is used (enable “Allow auto-merge” on the repo; if you use a
  //   merge queue, add `merge_group` to CI and required checks — see doc).
  // - Automerge is not instantaneous: Renovate serializes merges (~one meaningful
  //   automerge per base branch per run); frequent pushes to `main` delay others.
  // - Required reviews / CODEOWNERS block bot merges unless bypass actors,
  //   helper approve apps, or repo workflows approve with allowed tokens.
  // - `ignoreTests` below is scoped only where documented risk is acceptable.
  // ---------------------------------------------------------------------------
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    "docker:enableMajor",
    "helpers:pinGitHubActionDigests",
    ":automergeBranch",
    ":dependencyDashboard",
    ":disableRateLimiting",
    ":semanticCommits",
  ],
  // Explicit default on github.com: native platform automerge when Renovate merges PRs.
  platformAutomerge: true,
  dependencyDashboard: true,
  dependencyDashboardTitle: "Renovate Dashboard :robot:",
  schedule: ["every weekend"],
  ignorePaths: ["**/*.sops.*"],
  argocd: {
    managerFilePatterns: ["/(^|/)kubernetes/.+\\.ya?ml(?:\\.j2)?$/"],
  },
  helmfile: {
    managerFilePatterns: [
      "/(^|/)helmfile\\.ya?ml(?:\\.gotmpl)?(?:\\.j2)?$/",
      "/(^|/)helmfile\\.d/.+\\.ya?ml(?:\\.gotmpl)?(?:\\.j2)?$/",
    ],
  },
  kubernetes: {
    managerFilePatterns: ["/(^|/)kubernetes/.+\\.ya?ml(?:\\.j2)?$/"],
  },
  "helm-values": {
    managerFilePatterns: ["/(^|/)kubernetes/.+\\.ya?ml(?:\\.j2)?$/"],
  },
  packageRules: [
    {
      description:
        "Argo CD OCI Helm: argocd manager uses repoURL+chart as depName; overridePackageName fixes GHCR docker lookup. Do not overrideDepName — argocd update logic must keep the extracted depName or branch updates hit depName mismatch.",
      matchManagers: ["argocd"],
      matchDatasources: ["docker"],
      matchDepNames: ["ghcr.io/fluent/helm-charts/fluent-bit/fluent-bit"],
      overridePackageName: "ghcr.io/fluent/helm-charts/fluent-bit",
    },
    {
      description:
        "Argo CD OCI Helm: correct GHCR packageName for grafana-operator (depName unchanged for argocd updates)",
      matchManagers: ["argocd"],
      matchDatasources: ["docker"],
      matchDepNames: ["ghcr.io/grafana/helm-charts/grafana-operator/grafana-operator"],
      overridePackageName: "ghcr.io/grafana/helm-charts/grafana-operator",
    },
    {
      description:
        "Argo CD OCI Helm: correct GHCR packageName for victoria-logs-single (depName unchanged for argocd updates)",
      matchManagers: ["argocd"],
      matchDatasources: ["docker"],
      matchDepNames: [
        "ghcr.io/victoriametrics/helm-charts/victoria-logs-single/victoria-logs-single",
      ],
      overridePackageName: "ghcr.io/victoriametrics/helm-charts/victoria-logs-single",
    },
    {
      description:
        "Argo CD OCI Helm: correct GHCR packageName for tuppr (depName unchanged for argocd updates)",
      matchManagers: ["argocd"],
      matchDatasources: ["docker"],
      matchDepNames: ["ghcr.io/home-operations/charts/tuppr/tuppr"],
      overridePackageName: "ghcr.io/home-operations/charts/tuppr",
    },
    {
      description:
        "Argo CD chart version is duplicated in the Application manifest, bootstrap Helmfile, and templates/. Without grouping, Renovate can merge the same bump repeatedly because each location looks like a separate remaining update.",
      matchManagers: ["argocd", "helmfile"],
      matchDatasources: ["docker"],
      matchPackageNames: ["ghcr.io/argoproj/argo-helm/argo-cd"],
      groupName: "argo-cd-helm-chart",
    },
    {
      description: "Override Helmfile Dependency Name",
      matchDatasources: ["docker"],
      matchManagers: ["helmfile"],
      overrideDepName: "{{packageName}}",
    },
    {
      description: "Argo Operator Group",
      groupName: "argocd",
      matchDatasources: ["docker"],
      matchPackageNames: ["/argocd/"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      minimumGroupSize: 2,
    },
    {
      description:
        "Auto-merge GitHub Actions pin bumps (minor/patch/digest). ignoreTests: true because these repos rarely run actionable CI on renovate/** branches unless workflows include those triggers — see Renovate automerge doc § Absence of tests.",
      matchManagers: ["github-actions"],
      automerge: true,
      automergeType: "branch",
      matchUpdateTypes: ["minor", "patch", "digest"],
      minimumReleaseAge: "3 days",
      ignoreTests: true,
    },
    {
      description:
        "Auto-merge Mise tool bumps (minor/patch). ignoreTests: true — tool bumps don’t exercise cluster/app CI on this repo; tighten if you add targeted checks later.",
      matchManagers: ["mise"],
      automerge: true,
      automergeType: "branch",
      matchUpdateTypes: ["minor", "patch"],
      ignoreTests: true,
    },
    {
      matchUpdateTypes: ["major"],
      semanticCommitType: "feat",
      commitMessagePrefix: "{{semanticCommitType}}({{semanticCommitScope}})!:",
      commitMessageExtra: "( {{currentVersion}} ➔ {{newVersion}} )",
    },
    {
      matchUpdateTypes: ["minor"],
      semanticCommitType: "feat",
      commitMessageExtra: "( {{currentVersion}} ➔ {{newVersion}} )",
    },
    {
      matchUpdateTypes: ["patch"],
      semanticCommitType: "fix",
      commitMessageExtra: "( {{currentVersion}} ➔ {{newVersion}} )",
    },
    {
      matchUpdateTypes: ["digest"],
      semanticCommitType: "chore",
      commitMessageExtra: "( {{currentDigestShort}} ➔ {{newDigestShort}} )",
    },
    {
      matchDatasources: ["docker"],
      semanticCommitScope: "container",
      commitMessageTopic: "image {{depName}}",
    },
    {
      matchDatasources: ["helm"],
      semanticCommitScope: "helm",
      commitMessageTopic: "chart {{depName}}",
    },
    {
      matchManagers: ["github-actions"],
      semanticCommitType: "ci",
      semanticCommitScope: "github-action",
      commitMessageTopic: "action {{depName}}",
    },
    {
      matchDatasources: ["github-releases"],
      semanticCommitScope: "github-release",
      commitMessageTopic: "release {{depName}}",
    },
    {
      matchManagers: ["mise"],
      semanticCommitScope: "mise",
      commitMessageTopic: "tool {{depName}}",
    },
    {
      matchUpdateTypes: ["major"],
      labels: ["type/major"],
    },
    {
      matchUpdateTypes: ["minor"],
      labels: ["type/minor"],
    },
    {
      matchUpdateTypes: ["patch"],
      labels: ["type/patch"],
    },
    {
      matchUpdateTypes: ["digest"],
      labels: ["type/digest"],
    },
    {
      matchDatasources: ["docker"],
      addLabels: ["renovate/container"],
    },
    {
      matchDatasources: ["helm"],
      addLabels: ["renovate/helm"],
    },
    {
      matchManagers: ["github-actions"],
      addLabels: ["renovate/github-action"],
    },
    {
      matchDatasources: ["github-releases"],
      addLabels: ["renovate/github-release"],
    },
  ],
  customManagers: [
    {
      description: "Process annotated dependencies",
      customType: "regex",
      managerFilePatterns: [
        "/(^|/).+\\.env(?:\\.j2)?$/",
        "/(^|/).+\\.sh(?:\\.j2)?$/",
        "/(^|/).+\\.ya?ml(?:\\.j2)?$/",
      ],
      matchStrings: [
        // # renovate: datasource=github-releases depName=k3s-io/k3s
        // k3s_release_version: &version v1.29.0+k3s1
        // # renovate: datasource=helm depName=cilium repository=https://helm.cilium.io
        // version: 1.15.1
        // # renovate: datasource=docker depName=ghcr.io/siderolabs/kubelet
        // KUBERNETES_VERSION=v1.31.1
        "datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)( repository=(?<registryUrl>\\S+))?\\n.+(:\\s|=)(&\\S+\\s)?(?<currentValue>\\S+)",
        // # renovate: datasource=docker depName=ghcr.io/prometheus-operator/prometheus-operator
        // https://raw.githubusercontent.com/prometheus-operator/prometheus-operator/v0.80.0/example/prometheus-operator-crd/monitoring.coreos.com_alertmanagerconfigs.yaml
        "datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\n.+/(?<currentValue>(v|\\d)[^/]+)",
      ],
      datasourceTemplate: "{{#if datasource}}{{{datasource}}}{{else}}github-releases{{/if}}",
    },
    {
      customType: "regex",
      description: "Process OCI dependencies",
      managerFilePatterns: [
        "/\\.yaml(?:\\.j2)?$/",
      ],
      matchStrings: [
        "oci://(?<depName>[^:]+):(?<currentValue>\\S+)",
      ],
      datasourceTemplate: "docker",
    },
  ],
}
